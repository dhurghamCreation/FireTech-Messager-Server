#!/bin/bash
# FireTech Messenger - Linux Lite Final Fix

echo "Starting FireTech Deployment..."

# 1. Install dependencies
sudo apt update
sudo apt install -y git nodejs npm postgresql postgresql-contrib

# 2. Fix the "Role" and "Database" issue
echo "Configuring Database Permissions..."
sudo systemctl start postgresql

# This part is the 'Magic Fix':
# It creates a database user that matches his Linux name so he has permission.
USER_NAME=$(whoami)
sudo -u postgres psql -c "CREATE USER $USER_NAME WITH SUPERUSER;" 2>/dev/null
sudo -u postgres psql -c "ALTER USER $USER_NAME WITH PASSWORD 'password';" 2>/dev/null

# Now we create the railway database safely
sudo -u postgres psql -c "CREATE DATABASE railway;" 2>/dev/null || echo "Database 'railway' already exists, moving on..."

# 3. App Setup
cd ~
if [ ! -d "FireTech-Messager-Server" ]; then
    git clone https://github.com/dhurghamCreation/FireTech-Messager-Server.git
fi
cd FireTech-Messager-Server
npm install

# 4. Create .env (Updated with a safe local URL)
cat <<EOF > .env
DATABASE_URL=postgresql://$USER_NAME:password@localhost:5432/railway
JWT_SECRET=firetech_secret_123
PORT=3000
EOF

# 5. Launch
echo "FireTech Server is ready!"
node server.js
