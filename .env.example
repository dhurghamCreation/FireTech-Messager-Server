PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/discord-app

# JWT Secret
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# File uploads
MAX_FILE_SIZE=52428800

# CORS
CORS_ORIGIN=*

# SSL/HTTPS (optional)
SSL_PFX_PATH=
SSL_PFX_PASSPHRASE=
SSL_KEY_PATH=
SSL_CERT_PATH=
